#!/usr/bin/env bash
# wal-restore — restore last wal wallpaper and theme on login
# Wait for sway to be ready to accept clients
for i in $(seq 1 20); do
    swaymsg -t get_outputs &>/dev/null && break
    sleep 0.2
done
LAST=$(cat ~/.cache/wal/wal 2>/dev/null)
[[ -z "$LAST" || ! -f "$LAST" ]] && exit 0
~/.config/fzfmenu/wal-apply --quiet "$LAST"
