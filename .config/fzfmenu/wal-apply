#!/usr/bin/env bash
# wal-apply — apply a wallpaper and theme everything via pywal
# Usage: wal-apply /path/to/wallpaper.png

QUIET=0
[[ "$1" == "--quiet" ]] && {
    QUIET=1
    shift
}
WALLPAPER="$1"
[[ -z "$WALLPAPER" ]] && exit 1

# Ensure ~/.local/bin is in PATH (sway exec strips it from the user environment)
export PATH="$HOME/.local/bin:$PATH"

# 1. Generate color scheme from wallpaper
wal -i "$WALLPAPER" -n -q -t -e --contrast 3.0 --saturate 0.1 # -t=skip tty, -e=skip xrdb (blocks on Wayland with no X server)

# 2. swww sets the actual screen wallpaper
if ! swww query &>/dev/null; then
    swww-daemon &
    # Wait until daemon is connected to the compositor (avoids view_map crash in sway)
    for i in $(seq 1 20); do
        swww query &>/dev/null && break
        sleep 0.2
    done
fi
swww img "$WALLPAPER" --transition-type grow --transition-pos center

# 3. Copy wal kitty theme (sway controls opacity, keep kitty at 1.0)
cp ~/.cache/wal/colors-kitty.conf ~/.config/kitty/current-theme.conf
sed -i 's/^background_opacity.*/background_opacity 1.0/' ~/.config/kitty/current-theme.conf
kill -SIGUSR1 $(pidof kitty) 2>/dev/null

# 4. Update waybar style with new wal colors
source ~/.cache/wal/colors.sh
# Use style.css (the symlink waybar watches via inotify) not the real file path
# inotify on a symlink watches the link itself — writes to the target don't fire it
WAYBAR_STYLE="$HOME/.config/waybar/style.css"
# Write block to temp file to avoid shell interpolation issues in perl replacement
WAL_BLOCK_FILE=$(mktemp)
BG_R=$((16#${background:1:2}))
BG_G=$((16#${background:3:2}))
BG_B=$((16#${background:5:2}))
cat >"$WAL_BLOCK_FILE" <<WALEOF
/* wal-colors-start */
@define-color background ${background};
@define-color second-background mix(${background}, ${color7}, 0.15);
@define-color waybar-bg rgba(${BG_R}, ${BG_G}, ${BG_B}, 0.9);
@define-color text ${color7};
@define-color borders ${color1};
@define-color focused ${color4};
@define-color focused2 ${color5};
@define-color color1 ${color1};
@define-color color2 ${color2};
@define-color color3 ${color4};
@define-color urgent ${color8};
/* wal-colors-end */
WALEOF
export WAL_BLOCK_FILE
# Write via temp then use cat > to overwrite in-place, preserving the inode
# so waybar's inotify sees a modify event (CSS reload) not a delete+create (full restart)
WAYBAR_TMP=$(mktemp)
perl -0pe 's|/\* wal-colors-start \*/.*?/\* wal-colors-end \*/|`cat $ENV{WAL_BLOCK_FILE}`|se' "$WAYBAR_STYLE" >"$WAYBAR_TMP"
cat "$WAYBAR_TMP" >"$WAYBAR_STYLE"
rm -f "$WAL_BLOCK_FILE" "$WAYBAR_TMP"

# 5. Signal waybar to reload CSS (SIGUSR2 = reload style only, verified no duplicate on 0.13.0)
pkill -SIGUSR2 waybar 2>/dev/null || true

# 6. Update rofi wal colors
# Blend background+color1 at 25% for a subtle selected-item background
BG_R2=$((16#${background:1:2}))
BG_G2=$((16#${background:3:2}))
BG_B2=$((16#${background:5:2}))
C1_R=$((16#${color1:1:2}))
C1_G=$((16#${color1:3:2}))
C1_B=$((16#${color1:5:2}))
SEL_R=$((BG_R2 + (C1_R - BG_R2) * 25 / 100))
SEL_G=$((BG_G2 + (C1_G - BG_G2) * 25 / 100))
SEL_B=$((BG_B2 + (C1_B - BG_B2) * 25 / 100))
SELECTED_BG=$(printf "#%02x%02x%02x" $SEL_R $SEL_G $SEL_B)

cat >~/.config/rofi/wal.rasi <<ROFIEOF
/* wal-colors — auto-generated by wal-apply, do not edit manually */
* {
    background:     ${background};
    foreground:     ${color7};
    highlight:      ${color4};
    urgent:         ${color8};
    selected-bg:    ${SELECTED_BG};
}
ROFIEOF

# 7. Update tmux wal colors and reload all sessions
cat >~/.config/tmux/wal-colors.conf <<TMUXEOF
# wal-colors.conf — auto-generated by wal-apply, do not edit manually

# Status bar colors
set -g status-style                "fg=${color7},bg=${background}"
set -g status-left-style           "fg=${color4},bg=${background},bold"
set -g status-right-style          "fg=${color8},bg=${background}"

# Windows
set -g window-status-style         "fg=${color8},bg=${background}"
set -g window-status-current-style "fg=${color7},bg=${SELECTED_BG},bold"
set -g window-status-separator     "  "

# Pane borders
set -g pane-border-style           "fg=${SELECTED_BG}"
set -g pane-active-border-style    "fg=${color4}"

# Messages / command prompt
set -g message-style               "fg=${color7},bg=${SELECTED_BG}"
set -g message-command-style       "fg=${color4},bg=${SELECTED_BG}"

# Copy mode highlight
set -g mode-style                  "fg=${background},bg=${color4}"
TMUXEOF

# Reload all running tmux sessions
tmux list-sessions 2>/dev/null | while read -r s; do
    tmux source-file ~/.config/tmux/wal-colors.conf 2>/dev/null
    break
done

# 8. Reload sway border colors if in sway
if [[ "$SWAYSOCK" ]]; then
    source ~/.cache/wal/colors.sh
    swaymsg "client.focused ${color4} ${background} ${color7} ${color4} ${color4}" 2>/dev/null
    swaymsg "client.unfocused ${background} ${background} ${color8} ${background} ${background}" 2>/dev/null
fi

# 7. fzfmenu scripts — update fzf --color= from wal colors
BG=$(grep "^background " ~/.config/kitty/current-theme.conf | awk '{print $2}')
FG=$(grep "^foreground " ~/.config/kitty/current-theme.conf | awk '{print $2}')
C1=$(grep "^color1 " ~/.config/kitty/current-theme.conf | awk '{print $2}')
C4=$(grep "^color4 " ~/.config/kitty/current-theme.conf | awk '{print $2}')
C5=$(grep "^color5 " ~/.config/kitty/current-theme.conf | awk '{print $2}')
C6=$(grep "^color6 " ~/.config/kitty/current-theme.conf | awk '{print $2}')
C8=$(grep "^color8 " ~/.config/kitty/current-theme.conf | awk '{print $2}')

FZF_COLORS="bg:${BG},bg+:${SELECTED_BG},fg:${FG},fg+:${FG},hl:${C4},hl+:${C4},prompt:${C5},pointer:${C6},info:${C8},header:${C8}"
for script in ~/.config/fzfmenu/imgpick ~/.config/fzfmenu/wallpick ~/.config/fzfmenu/keybinds ~/.config/fzfmenu/layoutpick ~/.config/fzfmenu/bookmarks; do
    [[ -f "$script" ]] && sed -i "s|--color='[^']*'|--color='${FZF_COLORS}'|g" "$script"
done

# 8. Update fzfmenu wrapper background to match
sed -i "s|--override background=#[0-9a-fA-F]*|--override background=${BG}|g" ~/.config/fzfmenu/fzfmenu

# 9. Reload colorscheme in all running neovim instances
for sock in $(ls /run/user/$(id -u)/nvim.*.0 2>/dev/null); do
    nvim --server "$sock" --remote-send '<Esc>:colorscheme pywal16<CR>' 2>/dev/null
done

# 10. Reload qutebrowser config in all running instances
pgrep -x qutebrowser &>/dev/null && qutebrowser ':config-source' &>/dev/null &


[[ $QUIET -eq 0 ]] && notify-send -i "$WALLPAPER" "Theme applied" "$(basename "$WALLPAPER")"
